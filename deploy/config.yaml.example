# Production config for the systemd-managed install (deploy/install.sh).
# Lives at /etc/coraza-waf-mod/config.yaml. All paths below are absolute,
# rooted at /var/lib/coraza-waf-mod (the service's WorkingDirectory) since a
# systemd unit shouldn't depend on relative-path assumptions.

# ─── Network ─────────────────────────────────────────────────────────────────
listen_addr:     ":8080"  # change to ":80" once you're ready to go live behind tls.mode=auto/custom
listen_addr_tls: ":443"

# ─── TLS ─────────────────────────────────────────────────────────────────────
# mode: "off"    — plain HTTP (default; fine behind Cloudflare or for initial setup)
# mode: "auto"   — Let's Encrypt; server must be publicly reachable on port 80
# mode: "custom" — bring your own cert + key files
tls:
  mode: "off"
  cache_dir: "/var/lib/coraza-waf-mod/certs"

  # Uncomment for Let's Encrypt:
  # auto:
  #   domains:
  #     - "example.com"
  #   email: "admin@example.com"

  # Uncomment for custom cert:
  # custom:
  #   cert_file: "/var/lib/coraza-waf-mod/certs/cert.pem"
  #   key_file:  "/var/lib/coraza-waf-mod/certs/key.pem"

# ─── Geo Blocking ────────────────────────────────────────────────────────────
# The binary includes a bundled GeoLite2-Country.mmdb, so this can stay empty.
# To override it with an externally updated MaxMind database, set db_path to a
# readable .mmdb file, for example one maintained by geoipupdate.
geo:
  db_path: ""  # e.g. "/var/lib/coraza-waf-mod/GeoLite2-Country.mmdb"

# ─── WAF ─────────────────────────────────────────────────────────────────────
waf:
  enabled: true
  rules_dir: ""

# ─── Database ────────────────────────────────────────────────────────────────
db:
  path: "/var/lib/coraza-waf-mod/waf.db"
  log_retention_days: 30

# ─── Admin UI ────────────────────────────────────────────────────────────────
# install.sh generates a random password here on first install instead of
# shipping a default — change ADMIN_PASSWORD_PLACEHOLDER manually if you're
# deploying this file by hand instead.
admin:
  path: "/admin"
  username: "admin"
  password: "ADMIN_PASSWORD_PLACEHOLDER"

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Per-IP token-bucket limiter applied globally, ahead of geo/WAF inspection.
# Disabled by default — the right rate depends on your app's traffic shape.
rate_limit:
  enabled: false
  requests_per_second: 10  # sustained rate per client IP
  burst: 20                # max requests a client can burst before throttling

# ─── Backend Apps ────────────────────────────────────────────────────────────
# Only read once, on first-ever startup, to seed the services table — after
# that, manage backends from /admin/services instead of editing this file.
apps: []
